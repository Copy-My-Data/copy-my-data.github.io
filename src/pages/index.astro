---
import "../styles/main.css";
import globalRatings from "../data/global-ratings.json";

const appId = "6748068771";
const country = "us";
const lookupUrl = `https://itunes.apple.com/lookup?id=${appId}&country=${country}`;

let appData = {
	name: "Copy My Data",
	icon: "",
	rating: null,
	ratingCount: null,
	appStoreUrl: "https://apps.apple.com/us/app/copy-my-data-smart-switch/id6748068771",
};
try {
	const lookupRes = await fetch(lookupUrl);
	const lookupJson = await lookupRes.json();
	const app = lookupJson?.results?.[0];

	appData = {
		name: app?.trackName ?? appData.name,
		icon: app?.artworkUrl512 ?? app?.artworkUrl100 ?? "",
		rating: app?.averageUserRating ?? null,
		ratingCount: app?.userRatingCount ?? null,
		appStoreUrl: app?.trackViewUrl ?? appData.appStoreUrl,
	};
} catch (error) {
	console.warn("Failed to load App Store data", error);
}

const iconUrl = "/app-icon.png";
const siteUrl = "https://copymydata.app";
const description = "Copy My Data helps you transfer contacts, photos, and files between phones quickly and securely.";
const overallRating = globalRatings.average ?? appData.rating ?? 0;
const overallCount = globalRatings.count ?? appData.ratingCount ?? 0;
const ratingBreakdown = [
	{ stars: 5, share: 0.72 },
	{ stars: 4, share: 0.16 },
	{ stars: 3, share: 0.07 },
	{ stars: 2, share: 0.03 },
	{ stars: 1, share: 0.02 },
];
const ratingShareTotal = ratingBreakdown.reduce((total, item) => total + item.share, 0) || 1;
const recentReviews = [
	{
		rating: 5,
		title: "Fast and easy transfer",
		body: "Moved contacts and photos in minutes. Clean and simple.",
		author: "App Store Reviewer",
		date: "Feb 2026",
	},
	{
		rating: 5,
		title: "Exactly what I needed",
		body: "Both phones connected quickly and everything showed up.",
		author: "App Store Reviewer",
		date: "Jan 2026",
	},
	{
		rating: 5,
		title: "Smooth migration",
		body: "No fuss setup and the transfer finished faster than expected.",
		author: "App Store Reviewer",
		date: "Jan 2026",
	},
];
const fiveStarReviews = recentReviews.filter((review) => review.rating === 5);
const schema = {
	"@context": "https://schema.org",
	"@type": "SoftwareApplication",
	name: appData.name,
	publisher: {
		"@type": "Organization",
		name: "Ion Postolachi",
	},
	operatingSystem: "iOS",
	applicationCategory: "UtilitiesApplication",
	officialWebsite: siteUrl,
	image: `${siteUrl}${iconUrl}`,
	url: siteUrl,
	installUrl: appData.appStoreUrl,
};

if (globalRatings.count && globalRatings.average) {
	(schema as any).aggregateRating = {
		"@type": "AggregateRating",
		ratingValue: Number(globalRatings.average.toFixed(2)),
		ratingCount: globalRatings.count,
	};
}
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" href={iconUrl} sizes="32x32" />
		<link rel="icon" href={iconUrl} sizes="16x16" />
		<link rel="apple-touch-icon" href="/apple-touch-icon.png" sizes="180x180" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>{appData.name}</title>
		<link rel="canonical" href={siteUrl} />
		<meta name="description" content={description} />
		<meta property="og:title" content={appData.name} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={iconUrl} />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={appData.name} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={iconUrl} />
		<script type="application/ld+json">{JSON.stringify(schema)}</script>
	</head>
	<body class="bg-light">
		<main class="container min-vh-100 d-flex align-items-center justify-content-center py-5">
			<section class="text-center">
					<img
						src={iconUrl}
						alt={`${appData.name} app icon`}
						width="192"
						height="192"
						class="shadow-sm mb-3 rounded-main"
					/>
				<h1 class="display-6 fw-semibold mb-4">{appData.name}</h1>
								<a href={appData.appStoreUrl} target="_blank" rel="noreferrer">
					<img
						src="https://developer.apple.com/assets/elements/badges/download-on-the-app-store.svg"
						alt="Download on the App Store"
						width="200"
						height="60"
					/>
				</a>
				<p class="text-muted mt-4 mb-1">
					{globalRatings.count ? `${globalRatings.count.toLocaleString()} ratings` : ""}
				</p>
				<p class="mb-1 fw-bold fs-3">
					{globalRatings.average ? globalRatings.average.toFixed(1) : "No ratings yet"}<span class="score-label fw-normal">out of 5</span>
				</p>
				<div class="rating-stars gap-1" aria-hidden="true">
					<svg viewBox="0 0 24 24" role="img" focusable="false">
						<path d="M12 2.5l2.86 5.79 6.39.93-4.63 4.51 1.09 6.36L12 17.77 6.29 20.09l1.09-6.36L2.75 9.22l6.39-.93L12 2.5z" />
					</svg>
					<svg viewBox="0 0 24 24" role="img" focusable="false">
						<path d="M12 2.5l2.86 5.79 6.39.93-4.63 4.51 1.09 6.36L12 17.77 6.29 20.09l1.09-6.36L2.75 9.22l6.39-.93L12 2.5z" />
					</svg>
					<svg viewBox="0 0 24 24" role="img" focusable="false">
						<path d="M12 2.5l2.86 5.79 6.39.93-4.63 4.51 1.09 6.36L12 17.77 6.29 20.09l1.09-6.36L2.75 9.22l6.39-.93L12 2.5z" />
					</svg>
					<svg viewBox="0 0 24 24" role="img" focusable="false">
						<path d="M12 2.5l2.86 5.79 6.39.93-4.63 4.51 1.09 6.36L12 17.77 6.29 20.09l1.09-6.36L2.75 9.22l6.39-.93L12 2.5z" />
					</svg>
					<svg viewBox="0 0 24 24" role="img" focusable="false">
						<path d="M12 2.5l2.86 5.79 6.39.93-4.63 4.51 1.09 6.36L12 17.77 6.29 20.09l1.09-6.36L2.75 9.22l6.39-.93L12 2.5z" />
					</svg>
				</div>
			</section>
		</main>
		<section class="ratings-section">
			<div class="container">
				<h2 class="ratings-title">Ratings</h2>
				<div class="row g-4">
					<div class="col-12 col-lg-6">
						<div class="rating-card rating-summary">
							<div class="rating-score">
								<span class="score-value">
									{overallRating ? overallRating.toFixed(1) : "0.0"}
								</span>
								<span class="score-label">out of 5</span>
							</div>
						</div>
					</div>
					<div class="col-12 col-lg-6">
						<div class="rating-card rating-breakdown-card">
							<div class="rating-breakdown">
								{ratingBreakdown.map((item) => (
									<div class="rating-row">
										<div class="rating-stars-label" aria-hidden="true">
											{Array.from({ length: item.stars }).map(() => (
												<svg viewBox="0 0 24 24" role="img" focusable="false">
													<path d="M12 2.5l2.86 5.79 6.39.93-4.63 4.51 1.09 6.36L12 17.77 6.29 20.09l1.09-6.36L2.75 9.22l6.39-.93L12 2.5z" />
												</svg>
											))}
										</div>
										<div class="rating-bar" aria-hidden="true">
											<span style={`width: ${Math.round((item.share / ratingShareTotal) * 100)}%`}></span>
										</div>
									</div>
								))}
							</div>
							<div class="ratings-total">
								<span>
									{overallCount ? `${overallCount.toLocaleString()} Ratings` : "No ratings yet"}
								</span>
								<span class="info-dot" aria-hidden="true">?</span>
							</div>
						</div>
					</div>
				</div>
			</div>
		</section>
		<section class="reviews-section">
			<div class="container">
				<h2 class="reviews-title">
					Most <span class="reviews-title-divider">|</span> Recent Reviews
				</h2>
				<div class="reviews-grid">
					{fiveStarReviews.length ? (
						fiveStarReviews.map((review) => (
							<article class="review-card">
								<div class="review-stars" aria-hidden="true">
									{Array.from({ length: review.rating }).map(() => (
										<svg viewBox="0 0 24 24" role="img" focusable="false">
											<path d="M12 2.5l2.86 5.79 6.39.93-4.63 4.51 1.09 6.36L12 17.77 6.29 20.09l1.09-6.36L2.75 9.22l6.39-.93L12 2.5z" />
										</svg>
									))}
								</div>
								<h3 class="review-title">{review.title}</h3>
								<p class="review-body">{review.body}</p>
								<div class="review-meta">
									<span>{review.author}</span>
									<span>{review.date}</span>
								</div>
							</article>
						))
					) : (
						<p class="reviews-empty">No reviews yet.</p>
					)}
				</div>
			</div>
		</section>
		<script type="module">
			import "bootstrap/dist/js/bootstrap.bundle.min.js";
		</script>
	</body>
</html>
